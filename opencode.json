{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "description": "Lightweight autonomous feature implementation loop",
      "mode": "primary",
      "color": "#4ade80",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        "webfetch": "allow",
        "gh-issue_list": "allow",
        "gh-issue_view": "allow",
        "gh-issue_create": "allow",
        "gh-pr_list": "allow",
        "gh-pr_view": "allow",
        "gh-pr_create": "allow",
        "task": {
          "implementer": "allow",
          "reviewer": "allow",
          "explore": "allow"
        }
      }
    },
    "implementer": {
      "description": "Implements a single slice of a feature",
      "mode": "subagent",
      "hidden": true,
      "steps": 30,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "write": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow"
      }
    },
    "reviewer": {
      "description": "Read-only code review of diffs",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "git diff": "allow",
          "git log*": "allow",
          "grep *": "allow"
        }
      }
    }
  }
}
